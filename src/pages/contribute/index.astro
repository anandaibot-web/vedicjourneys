---
// src/pages/contribute/index.astro
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/contribute/login?error=auth');

const { handle, name } = session;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Share Your Journey — Vedic Journeys</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <!-- Cloudinary Upload Widget -->
  <script src="https://upload-widget.cloudinary.com/global/all.js" type="text/javascript"></script>
  <style>
    :root {
      --cream: #faf7f2; --warm: #f0ebe0; --sand: #d4c5a9;
      --terracotta: #b5673d; --saffron: #e8922a; --deep: #2c1810;
      --mid: #6b4c38; --light: #9a7b68; --green: #3d7a5a;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Crimson Pro', Palatino, Georgia, serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--cream);
      font-family: var(--sans);
      font-size: 17px;
      color: var(--deep);
      min-height: 100vh;
    }

    /* ── Nav ── */
    nav {
      background: var(--deep);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand {
      font-family: var(--serif);
      color: white;
      font-size: 1.1rem;
      text-decoration: none;
    }
    .nav-user {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      font-size: 0.85rem;
    }
    .nav-handle {
      color: var(--sand);
    }
    .nav-logout {
      color: var(--light);
      text-decoration: none;
      font-size: 0.8rem;
      transition: color 0.2s;
    }
    .nav-logout:hover { color: white; }

    /* ── Page header ── */
    .page-header {
      max-width: 780px;
      margin: 0 auto;
      padding: 3.5rem 2rem 2rem;
    }
    .page-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      color: var(--deep);
      margin-bottom: 0.5rem;
    }
    .page-subtitle {
      color: var(--light);
      font-size: 0.95rem;
    }

    /* ── Form ── */
    .form-wrap {
      max-width: 780px;
      margin: 0 auto;
      padding: 0 2rem 5rem;
    }

    .section-title {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--sand);
    }

    /* ── Image upload zone ── */
    .upload-section { margin-bottom: 3rem; }

    .upload-zone {
      border: 2px dashed var(--sand);
      border-radius: 4px;
      padding: 3rem 2rem;
      text-align: center;
      background: white;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
    }
    .upload-zone:hover, .upload-zone.dragover {
      border-color: var(--terracotta);
      background: #fdf8f4;
    }
    .upload-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .upload-text {
      font-family: var(--serif);
      font-size: 1.2rem;
      color: var(--deep);
      margin-bottom: 0.5rem;
    }
    .upload-hint { font-size: 0.85rem; color: var(--light); }

    .upload-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.25rem;
      padding: 0.7rem 1.75rem;
      background: var(--terracotta);
      color: white;
      border: none;
      border-radius: 2px;
      font-family: var(--sans);
      font-size: 0.9rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .upload-btn:hover { background: var(--deep); }

    /* Image previews */
    .image-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 0.75rem;
      margin-top: 1.25rem;
    }
    .image-thumb {
      position: relative;
      aspect-ratio: 1;
      border-radius: 3px;
      overflow: hidden;
      background: var(--warm);
    }
    .image-thumb img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
    }
    .image-thumb .remove {
      position: absolute;
      top: 4px; right: 4px;
      width: 22px; height: 22px;
      background: rgba(44,24,16,0.8);
      color: white;
      border: none;
      border-radius: 50%;
      font-size: 0.75rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .image-count {
      margin-top: 0.75rem;
      font-size: 0.85rem;
      color: var(--mid);
    }

    /* ── Context form ── */
    .context-section { margin-bottom: 3rem; }

    .field { margin-bottom: 1.5rem; }

    label {
      display: block;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 0.5rem;
    }
    .field-hint {
      font-size: 0.8rem;
      color: var(--light);
      margin-bottom: 0.5rem;
      font-style: italic;
    }
    input[type="text"], input[type="date"], textarea, select {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--sand);
      border-radius: 2px;
      background: white;
      font-family: var(--sans);
      font-size: 1rem;
      color: var(--deep);
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, textarea:focus, select:focus {
      border-color: var(--terracotta);
    }
    textarea { resize: vertical; line-height: 1.6; }
    input::placeholder, textarea::placeholder { color: var(--light); }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    /* ── Visibility toggle ── */
    .visibility-options {
      display: flex;
      gap: 1rem;
    }
    .vis-option {
      flex: 1;
      border: 1px solid var(--sand);
      border-radius: 2px;
      padding: 0.875rem 1rem;
      cursor: pointer;
      transition: all 0.15s;
      background: white;
    }
    .vis-option:has(input:checked) {
      border-color: var(--terracotta);
      background: #fdf8f4;
    }
    .vis-option input { display: none; }
    .vis-label {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--deep);
      margin-bottom: 0.2rem;
    }
    .vis-desc { font-size: 0.8rem; color: var(--light); }

    /* ── Submit ── */
    .submit-section {
      padding-top: 1.5rem;
      border-top: 1px solid var(--sand);
    }
    .submit-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 2.5rem;
      background: var(--deep);
      color: white;
      border: none;
      border-radius: 2px;
      font-family: var(--sans);
      font-size: 1.05rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .submit-btn:hover:not(:disabled) { background: var(--terracotta); }
    .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Status / result ── */
    #status {
      margin-top: 2rem;
      padding: 1.25rem 1.5rem;
      border-radius: 3px;
      display: none;
      font-size: 0.95rem;
    }
    #status.processing {
      display: block;
      background: var(--warm);
      border: 1px solid var(--sand);
      color: var(--mid);
    }
    #status.success {
      display: block;
      background: #f0f7f4;
      border: 1px solid var(--green);
      color: #2a5a3f;
    }
    #status.error {
      display: block;
      background: #fdf0ec;
      border: 1px solid var(--terracotta);
      color: var(--terracotta);
    }
    .result-url {
      margin-top: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .result-url a {
      color: var(--green);
      font-weight: 600;
      word-break: break-all;
    }
    .copy-btn {
      padding: 0.35rem 0.75rem;
      background: var(--green);
      color: white;
      border: none;
      border-radius: 2px;
      font-size: 0.8rem;
      cursor: pointer;
    }

    /* ── Recent posts ── */
    .recent-section { margin-top: 4rem; }
    .recent-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
      margin-top: 1.25rem;
    }
    .recent-item {
      border: 1px solid var(--warm);
      border-radius: 3px;
      padding: 1rem;
      background: white;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s;
      display: block;
    }
    .recent-item:hover { border-color: var(--terracotta); }
    .recent-title {
      font-family: var(--serif);
      font-size: 0.95rem;
      color: var(--deep);
      margin-bottom: 0.35rem;
      line-height: 1.3;
    }
    .recent-meta { font-size: 0.75rem; color: var(--light); }

    @media (max-width: 600px) {
      .field-row { grid-template-columns: 1fr; }
      .visibility-options { flex-direction: column; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-brand">✦ Vedic Journeys</a>
    <div class="nav-user">
      <span class="nav-handle">@{handle}</span>
      <a href="/api/auth/logout" class="nav-logout">Sign out</a>
    </div>
  </nav>

  <div class="page-header">
    <h1 class="page-title">Share your journey</h1>
    <p class="page-subtitle">Upload your photos and add context — your blog post will be ready in about a minute.</p>
  </div>

  <div class="form-wrap">

    <!-- ── Images ── -->
    <section class="upload-section">
      <p class="section-title">Your photos</p>

      <div class="upload-zone" id="upload-zone">
        <div class="upload-icon">📷</div>
        <p class="upload-text">Drop photos here</p>
        <p class="upload-hint">JPEG, PNG, WEBP · Up to 10 images · 20MB each</p>
        <button type="button" class="upload-btn" id="upload-trigger">
          Choose photos
        </button>
      </div>

      <div class="image-grid" id="image-grid"></div>
      <p class="image-count" id="image-count"></p>
    </section>

    <!-- ── Context form ── -->
    <section class="context-section">
      <p class="section-title">Trip context</p>
      <p style="color: var(--mid); font-size:0.95rem; margin-bottom:1.5rem;">
        The more you share, the more authentic and personal your post will be.
        Every field is optional — but location makes a big difference.
      </p>

      <div class="field">
        <label for="location">Location <span style="color:var(--terracotta)">*</span></label>
        <p class="field-hint">Be specific — "Manasarovar Lake, Tibet" not just "Tibet"</p>
        <input type="text" id="location" name="location"
          placeholder="e.g. Kedarnath Temple, Uttarakhand, India" />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="trip-date">Date of journey</label>
          <input type="date" id="trip-date" name="trip_date" />
        </div>
        <div class="field">
          <label for="altitude">Altitude (metres)</label>
          <input type="text" id="altitude" name="altitude" placeholder="e.g. 4500" />
        </div>
      </div>

      <div class="field">
        <label for="one-line">One line — what made this moment special?</label>
        <input type="text" id="one-line" name="one_line"
          placeholder="e.g. First dawn at the lake after a 3-day walk" />
      </div>

      <div class="field">
        <label for="reflection">Personal reflection</label>
        <p class="field-hint">What were you thinking or feeling? This becomes your voice in the post.</p>
        <textarea id="reflection" name="reflection" rows="4"
          placeholder="e.g. I had been carrying a question about grief for three years. Something about the silence at 4,500m began to answer it..."></textarea>
      </div>

      <div class="field-row">
        <div class="field">
          <label for="challenge">Physical or emotional challenge</label>
          <textarea id="challenge" name="challenge" rows="3"
            placeholder="e.g. Altitude sickness on day 2. Couldn't eat. Kept walking."></textarea>
        </div>
        <div class="field">
          <label for="intention">Why this journey?</label>
          <textarea id="intention" name="intention" rows="3"
            placeholder="e.g. Pilgrimage for my father. He always wanted to go to Kailash."></textarea>
        </div>
      </div>

      <div class="field">
        <label>Visibility</label>
        <div class="visibility-options">
          <label class="vis-option">
            <input type="radio" name="visibility" value="unlisted" checked />
            <div class="vis-label">🔗 Unlisted</div>
            <div class="vis-desc">Only people with the link can see it</div>
          </label>
          <label class="vis-option">
            <input type="radio" name="visibility" value="public" />
            <div class="vis-label">🌍 Public</div>
            <div class="vis-desc">Listed on the site for everyone</div>
          </label>
        </div>
      </div>
    </section>

    <!-- ── Submit ── -->
    <div class="submit-section">
      <button class="submit-btn" id="submit-btn" disabled>
        <span id="submit-icon">✦</span>
        <span id="submit-label">Generate my post</span>
      </button>
      <p style="margin-top:0.75rem; font-size:0.8rem; color:var(--light);">
        Takes ~60–90 seconds. You'll see the link here when it's ready.
      </p>
    </div>

    <div id="status"></div>

    <!-- ── Recent posts ── -->
    <section class="recent-section">
      <p class="section-title">Your recent posts</p>
      <div id="recent-posts" class="recent-grid">
        <p style="color:var(--light); font-size:0.9rem;">Loading…</p>
      </div>
    </section>

  </div>

  <script define:vars={{ handle, CLOUDINARY_CLOUD: import.meta.env.PUBLIC_CLOUDINARY_CLOUD, CLOUDINARY_PRESET: import.meta.env.PUBLIC_CLOUDINARY_PRESET }}>

    // ── Cloudinary upload ──────────────────────────────────────────────────
    const uploadedImages = []; // { publicId, url, secureUrl }

    const widget = cloudinary.createUploadWidget({
      cloudName: CLOUDINARY_CLOUD,
      uploadPreset: CLOUDINARY_PRESET,
      multiple: true,
      maxFiles: 10,
      maxFileSize: 20 * 1024 * 1024,
      resourceType: 'image',
      sources: ['local', 'camera'],
      styles: {
        palette: {
          window: '#faf7f2',
          windowBorder: '#d4c5a9',
          tabIcon: '#b5673d',
          menuIcons: '#6b4c38',
          textDark: '#2c1810',
          textLight: '#ffffff',
          link: '#b5673d',
          action: '#b5673d',
          inactiveTabIcon: '#9a7b68',
          error: '#cc0000',
          inProgress: '#e8922a',
          complete: '#3d7a5a',
          sourceBg: '#f0ebe0',
        }
      }
    }, (error, result) => {
      if (error) { console.error('Upload error:', error); return; }
      if (result.event === 'success') {
        const info = result.info;
        uploadedImages.push({
          publicId: info.public_id,
          url: info.url,
          secureUrl: info.secure_url,
          thumbnailUrl: info.thumbnail_url,
        });
        renderPreviews();
        updateSubmitState();
      }
    });

    document.getElementById('upload-trigger').addEventListener('click', () => widget.open());
    document.getElementById('upload-zone').addEventListener('click', (e) => {
      if (e.target.tagName !== 'BUTTON') widget.open();
    });

    function renderPreviews() {
      const grid = document.getElementById('image-grid');
      const count = document.getElementById('image-count');
      grid.innerHTML = uploadedImages.map((img, i) => `
        <div class="image-thumb">
          <img src="${img.thumbnailUrl || img.secureUrl}" alt="Photo ${i+1}" />
          <button class="remove" onclick="removeImage(${i})">✕</button>
        </div>
      `).join('');
      count.textContent = uploadedImages.length > 0
        ? `${uploadedImages.length} photo${uploadedImages.length > 1 ? 's' : ''} ready`
        : '';
    }

    window.removeImage = (i) => {
      uploadedImages.splice(i, 1);
      renderPreviews();
      updateSubmitState();
    };

    function updateSubmitState() {
      document.getElementById('submit-btn').disabled = uploadedImages.length === 0;
    }

    // ── Form submission ────────────────────────────────────────────────────
    document.getElementById('submit-btn').addEventListener('click', async () => {
      if (uploadedImages.length === 0) return;

      const btn = document.getElementById('submit-btn');
      const status = document.getElementById('status');
      const label = document.getElementById('submit-label');
      const icon = document.getElementById('submit-icon');

      btn.disabled = true;
      label.textContent = 'Generating…';
      icon.textContent = '⏳';

      status.className = 'processing';
      status.style.display = 'block';
      status.innerHTML = `
        <strong>✦ Generating your post…</strong><br>
        <span style="color:var(--light); font-size:0.9rem;">
          Analysing images, identifying landmarks, writing your story.<br>
          This takes about 60–90 seconds.
        </span>`;

      const payload = {
        handle,
        images: uploadedImages.map(img => ({ publicId: img.publicId, url: img.secureUrl })),
        context: {
          location: document.getElementById('location').value.trim(),
          trip_date: document.getElementById('trip-date').value,
          altitude: document.getElementById('altitude').value.trim(),
          one_line: document.getElementById('one-line').value.trim(),
          reflection: document.getElementById('reflection').value.trim(),
          challenge: document.getElementById('challenge').value.trim(),
          intention: document.getElementById('intention').value.trim(),
          visibility: document.querySelector('input[name="visibility"]:checked').value,
        }
      };

      try {
        const res = await fetch('/api/contribute/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await res.json();

        if (res.ok && data.url) {
          status.className = 'success';
          status.innerHTML = `
            <strong>✅ Your post is live!</strong>
            <div class="result-url">
              <a href="${data.url}" target="_blank">${data.url}</a>
              <button class="copy-btn" onclick="navigator.clipboard.writeText('${data.url}');this.textContent='Copied!'">Copy</button>
            </div>
            <p style="margin-top:0.75rem; font-size:0.85rem; color:#2a5a3f;">
              Quality score: ${data.quality}/100 · ${data.wordCount} words
            </p>`;
          label.textContent = 'Generate another post';
          icon.textContent = '✦';
          btn.disabled = false;
          loadRecentPosts();
        } else {
          throw new Error(data.error || 'Unknown error');
        }
      } catch (err) {
        status.className = 'error';
        status.innerHTML = `<strong>❌ Something went wrong</strong><br>${err.message}`;
        label.textContent = 'Try again';
        icon.textContent = '✦';
        btn.disabled = false;
      }
    });

    // ── Load recent posts ──────────────────────────────────────────────────
    async function loadRecentPosts() {
      try {
        const res = await fetch(`/api/contribute/posts?handle=${handle}`);
        const data = await res.json();
        const container = document.getElementById('recent-posts');

        if (!data.posts?.length) {
          container.innerHTML = '<p style="color:var(--light); font-size:0.9rem;">No posts yet. Share your first journey above.</p>';
          return;
        }

        container.innerHTML = data.posts.map(p => `
          <a href="${p.url}" target="_blank" class="recent-item">
            <div class="recent-title">${p.title}</div>
            <div class="recent-meta">
              ${p.location ? `📍 ${p.location} · ` : ''}${p.date}
            </div>
          </a>
        `).join('');
      } catch {}
    }

    loadRecentPosts();
  </script>

</body>
</html>
