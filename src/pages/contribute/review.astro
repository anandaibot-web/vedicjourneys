---
// src/pages/contribute/review.astro
// Review flagged posts + manage visibility of published posts
import { getSession } from '../../lib/auth';
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/contribute/login');
const handle = session.handle;

const BLOG_ROOT = path.join(process.cwd(), 'src/content/blog');
const REVIEW_DIR = path.join(BLOG_ROOT, '_review', handle);
const PUBLISHED_DIR = path.join(BLOG_ROOT, handle);

function readPosts(dir: string) {
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter(f => f.endsWith('.md'))
    .map(f => {
      const raw = fs.readFileSync(path.join(dir, f), 'utf8');
      const { data } = matter(raw);
      return { slug: f.replace('.md', ''), ...data };
    })
    .sort((a: any, b: any) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf());
}

const reviewPosts = readPosts(REVIEW_DIR);
const publishedPosts = readPosts(PUBLISHED_DIR);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Review Posts — Vedic Journeys</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #faf7f2; --warm: #f0ebe0; --sand: #d4c5a9;
      --terracotta: #b5673d; --deep: #2c1810; --mid: #6b4c38; --light: #9a7b68;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Crimson Pro', Palatino, Georgia, serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--cream); color: var(--deep); font-family: var(--sans); min-height: 100vh; }

    /* Nav */
    .nav { background: var(--deep); padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; }
    .nav-brand { font-family: var(--serif); color: #fff; text-decoration: none; font-size: 1rem; }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: var(--sand); text-decoration: none; font-size: 0.85rem; font-family: var(--sans); }
    .nav-links a:hover { color: #fff; }
    .nav-links a.active { color: var(--terracotta); }

    /* Page */
    .page { max-width: 1000px; margin: 0 auto; padding: 3rem 2rem 5rem; }
    .page-title { font-family: var(--serif); font-size: 2rem; margin-bottom: 0.5rem; }
    .page-sub { color: var(--light); font-size: 0.95rem; margin-bottom: 3rem; }

    /* Section */
    .section { margin-bottom: 3.5rem; }
    .section-header {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--sand);
    }
    .section-title { font-family: var(--serif); font-size: 1.3rem; }
    .badge {
      font-size: 0.7rem; font-family: sans-serif; padding: 0.2rem 0.6rem;
      border-radius: 999px; letter-spacing: 0.05em;
    }
    .badge-review { background: #fff3cd; color: #856404; }
    .badge-published { background: #d1e7dd; color: #0a3622; }
    .empty { color: var(--light); font-style: italic; padding: 1.5rem 0; }

    /* Post row */
    .post-row {
      display: flex; align-items: flex-start; gap: 1.5rem;
      padding: 1.25rem 0;
      border-bottom: 1px solid var(--warm);
    }
    .post-row:last-child { border-bottom: none; }
    .post-thumb {
      width: 80px; height: 60px; object-fit: cover;
      border-radius: 2px; flex-shrink: 0; background: var(--warm);
    }
    .post-info { flex: 1; min-width: 0; }
    .post-title { font-family: var(--serif); font-size: 1rem; margin-bottom: 0.25rem; line-height: 1.3; }
    .post-meta { font-size: 0.8rem; color: var(--light); display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
    .quality-score { font-size: 0.75rem; font-family: sans-serif; }
    .score-ok { color: #198754; }
    .score-warn { color: #856404; }
    .post-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; flex-shrink: 0; }

    /* Buttons */
    .btn {
      padding: 0.4rem 0.9rem; border: none; border-radius: 2px;
      font-family: var(--sans); font-size: 0.85rem; cursor: pointer;
      transition: all 0.2s; text-decoration: none; display: inline-block;
    }
    .btn-approve { background: #198754; color: white; }
    .btn-approve:hover { background: #146c43; }
    .btn-reject { background: #dc3545; color: white; }
    .btn-reject:hover { background: #b02a37; }
    .btn-public { background: var(--terracotta); color: white; }
    .btn-public:hover { background: var(--deep); }
    .btn-unlisted { background: var(--warm); color: var(--mid); border: 1px solid var(--sand); }
    .btn-unlisted:hover { background: var(--sand); }
    .btn-preview { background: transparent; color: var(--mid); border: 1px solid var(--sand); }
    .btn-preview:hover { border-color: var(--mid); }
    .btn-edit { background: var(--warm); color: var(--mid); border: 1px solid var(--sand); }
    .btn-edit:hover { background: var(--sand); border-color: var(--mid); }
    .btn-remove { background: transparent; color: #dc3545; border: 1px solid #dc3545; }
    .btn-remove:hover { background: #dc3545; color: white; }
    .btn-cancel { background: var(--warm); color: var(--mid); border: 1px solid var(--sand); }
    .btn-cancel:hover { background: var(--sand); }
    .btn-save { background: var(--deep); color: white; }
    .btn-save:hover { background: var(--terracotta); }

    /* Edit modal */
    .modal-overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(44,24,16,0.5);
      z-index: 100;
      overflow-y: auto;
      padding: 2rem 1rem;
    }
    .modal-overlay.open { display: flex; align-items: flex-start; justify-content: center; }
    .modal {
      background: var(--cream);
      border-radius: 4px;
      width: 100%; max-width: 720px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.25);
    }
    .modal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--sand);
    }
    .modal-title { font-family: var(--serif); font-size: 1.2rem; }
    .modal-close {
      background: none; border: none; cursor: pointer;
      color: var(--light); font-size: 1.1rem; line-height: 1;
      padding: 0.25rem 0.5rem;
    }
    .modal-close:hover { color: var(--deep); }
    .modal-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
    .modal-footer {
      display: flex; gap: 0.75rem; justify-content: flex-end;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--sand);
    }
    .modal-field label {
      display: block;
      font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--mid); margin-bottom: 0.4rem;
    }
    .modal-field input, .modal-field textarea, .modal-field select {
      width: 100%;
      padding: 0.65rem 0.85rem;
      border: 1px solid var(--sand); border-radius: 2px;
      background: white; font-family: var(--sans); font-size: 1rem;
      color: var(--deep); outline: none;
    }
    .modal-field input:focus, .modal-field textarea:focus { border-color: var(--terracotta); }
    .modal-field textarea { resize: vertical; line-height: 1.6; }
    .modal-field textarea.mono { font-family: 'Courier New', monospace; font-size: 0.85rem; }
    .modal-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .modal-vis { display: flex; gap: 0.75rem; }
    .modal-vis-option {
      flex: 1; border: 1px solid var(--sand); border-radius: 2px;
      padding: 0.6rem 0.85rem; cursor: pointer; background: white;
    }
    .modal-vis-option:has(input:checked) { border-color: var(--terracotta); background: #fdf8f4; }
    .modal-vis-option input { display: none; }
    .modal-vis-label { font-size: 0.85rem; color: var(--deep); }
    .modal-loading {
      text-align: center; padding: 3rem; color: var(--light); font-style: italic;
    }
    .vis-badge {
      font-size: 0.7rem; font-family: sans-serif; padding: 0.2rem 0.5rem;
      border-radius: 999px; align-self: center;
    }
    .vis-public { background: #d1e7dd; color: #0a3622; }
    .vis-unlisted { background: #fff3cd; color: #856404; }

    /* Toast */
    .toast {
      position: fixed; bottom: 2rem; right: 2rem;
      background: var(--deep); color: white;
      padding: 0.75rem 1.25rem; border-radius: 4px;
      font-family: var(--sans); font-size: 0.9rem;
      display: none; z-index: 999;
    }
    .toast.show { display: block; }
  </style>
</head>
<body>

  <nav class="nav">
    <a href="/" class="nav-brand">✦ Vedic Journeys</a>
    <div class="nav-links">
      <a href="/contribute">Upload</a>
      <a href="/contribute/review" class="active">Review</a>
      <a href={"/u/" + handle}>My Profile</a>
      <a href="/api/auth/logout">Logout</a>
    </div>
  </nav>

  <div class="page">
    <h1 class="page-title">Post Manager</h1>
    <p class="page-sub">Review flagged drafts and manage visibility of published posts.</p>

    <!-- Flagged / Review section -->
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">Needs Review</h2>
        <span class="badge badge-review">{reviewPosts.length} post{reviewPosts.length !== 1 ? 's' : ''}</span>
      </div>

      {reviewPosts.length === 0
        ? <p class="empty">No posts awaiting review. ✓</p>
        : reviewPosts.map((post: any) => (
          <div class="post-row" id={"review-" + post.slug}>
            {post.heroImage && (
              <img src={post.heroImage} alt={post.title} class="post-thumb" />
            )}
            <div class="post-info">
              <p class="post-title">{post.title}</p>
              <div class="post-meta">
                {post.location && <span>📍 {post.location}</span>}
                {post.pubDate && <span>📅 {new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
                {post.qualityScore && (
                  <span class={"quality-score " + (post.qualityScore >= 90 ? 'score-ok' : 'score-warn')}>
                    Score: {post.qualityScore}/100
                  </span>
                )}
              </div>
            </div>
            <div class="post-actions">
              <button class="btn btn-approve" data-action="approve" data-slug={post.slug}>
                ✓ Approve
              </button>
              <button class="btn btn-reject" data-action="reject" data-slug={post.slug}>
                ✕ Delete
              </button>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Published posts section -->
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">Published Posts</h2>
        <span class="badge badge-published">{publishedPosts.length} post{publishedPosts.length !== 1 ? 's' : ''}</span>
      </div>

      {publishedPosts.length === 0
        ? <p class="empty">No published posts yet.</p>
        : publishedPosts.map((post: any) => (
          <div class="post-row" id={"pub-" + post.slug}>
            {post.heroImage && (
              <img src={post.heroImage} alt={post.title} class="post-thumb" />
            )}
            <div class="post-info">
              <p class="post-title">{post.title}</p>
              <div class="post-meta">
                {post.location && <span>📍 {post.location}</span>}
                {post.pubDate && <span>📅 {new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
                {post.readTime && <span>⏱ {post.readTime} min read</span>}
              </div>
            </div>
            <span class={"vis-badge " + (post.visibility === 'public' ? 'vis-public' : 'vis-unlisted')} id={"vis-" + post.slug}>
              {post.visibility === 'public' ? '🌐 Public' : '🔒 Unlisted'}
            </span>
            <div class="post-actions">
              {post.visibility !== 'public'
                ? <button class="btn btn-public" data-action="visibility" data-slug={post.slug} data-visibility="public">Make Public</button>
                : <button class="btn btn-unlisted" data-action="visibility" data-slug={post.slug} data-visibility="unlisted">Make Unlisted</button>
              }
              <button class="btn btn-edit" data-action="edit" data-slug={post.slug}>Edit</button>
              <button class="btn btn-remove" data-action="remove" data-slug={post.slug}>Remove</button>
              <a href={"/u/" + handle + "/" + post.slug} target="_blank" class="btn btn-preview">Preview →</a>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <!-- Edit Modal -->
  <div class="modal-overlay" id="edit-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal">
      <div class="modal-header">
        <span class="modal-title" id="modal-title">Edit Post</span>
        <button class="modal-close" id="modal-close-btn" aria-label="Close">✕</button>
      </div>
      <div class="modal-body" id="modal-body">
        <div class="modal-loading">Loading post…</div>
      </div>
      <div class="modal-footer" id="modal-footer" style="display:none;">
        <button class="btn btn-cancel" id="edit-cancel">Cancel</button>
        <button class="btn btn-save" id="edit-save">Save &amp; Publish</button>
      </div>
    </div>
  </div>

  <script>
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3000);
    }

    async function apiCall(payload) {
      const res = await fetch('/api/contribute/review', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      return { ok: res.ok, data: await res.json() };
    }

    // ── Edit modal ─────────────────────────────────────────────────────────
    const modal = document.getElementById('edit-modal');
    const modalBody = document.getElementById('modal-body');
    const modalFooter = document.getElementById('modal-footer');
    let currentEditSlug = null;

    function openModal() {
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
      currentEditSlug = null;
      modalBody.innerHTML = '<div class="modal-loading">Loading post…</div>';
      modalFooter.style.display = 'none';
    }

    document.getElementById('modal-close-btn').addEventListener('click', closeModal);
    document.getElementById('edit-cancel').addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    async function openEditModal(slug) {
      currentEditSlug = slug;
      openModal();

      try {
        const res = await fetch(`/api/contribute/post?slug=${encodeURIComponent(slug)}`);
        if (!res.ok) throw new Error('Failed to load post');
        const { frontmatter: fm, body } = await res.json();

        modalBody.innerHTML = `
          <div class="modal-row">
            <div class="modal-field">
              <label>Title</label>
              <input type="text" id="edit-title" value="${escHtml(fm.title || '')}" />
            </div>
            <div class="modal-field">
              <label>Location</label>
              <input type="text" id="edit-location" value="${escHtml(fm.location || '')}" />
            </div>
          </div>
          <div class="modal-field">
            <label>Description</label>
            <textarea id="edit-description" rows="2">${escHtml(fm.description || '')}</textarea>
          </div>
          <div class="modal-field">
            <label>Visibility</label>
            <div class="modal-vis">
              <label class="modal-vis-option">
                <input type="radio" name="edit-vis" value="public" ${fm.visibility === 'public' ? 'checked' : ''} />
                <div class="modal-vis-label">🌐 Public</div>
              </label>
              <label class="modal-vis-option">
                <input type="radio" name="edit-vis" value="unlisted" ${fm.visibility !== 'public' ? 'checked' : ''} />
                <div class="modal-vis-label">🔒 Unlisted</div>
              </label>
            </div>
          </div>
          <div class="modal-field">
            <label>Content (Markdown)</label>
            <textarea id="edit-body" class="mono" rows="22">${escHtml(body || '')}</textarea>
          </div>
        `;
        modalFooter.style.display = 'flex';
      } catch (err) {
        modalBody.innerHTML = `<div class="modal-loading" style="color:var(--terracotta);">Failed to load post: ${err.message}</div>`;
      }
    }

    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    document.getElementById('edit-save').addEventListener('click', async () => {
      if (!currentEditSlug) return;
      const saveBtn = document.getElementById('edit-save');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving…';

      const title = document.getElementById('edit-title')?.value.trim() || '';
      const description = document.getElementById('edit-description')?.value.trim() || '';
      const location = document.getElementById('edit-location')?.value.trim() || '';
      const visibility = document.querySelector('input[name="edit-vis"]:checked')?.value || 'unlisted';
      const body = document.getElementById('edit-body')?.value || '';

      const { ok, data } = await apiCall({
        action: 'edit',
        slug: currentEditSlug,
        title,
        description,
        location,
        visibility,
        body,
      });

      if (ok) {
        // Update the row title in the list
        const row = document.getElementById('pub-' + currentEditSlug);
        if (row) {
          const titleEl = row.querySelector('.post-title');
          if (titleEl) titleEl.textContent = title;

          // Update visibility badge and toggle button
          const badge = document.getElementById('vis-' + currentEditSlug);
          if (badge) {
            badge.textContent = visibility === 'public' ? '🌐 Public' : '🔒 Unlisted';
            badge.className = 'vis-badge ' + (visibility === 'public' ? 'vis-public' : 'vis-unlisted');
          }
          const visBtn = row.querySelector('button[data-action="visibility"]');
          if (visBtn) {
            const newVis = visibility === 'public' ? 'unlisted' : 'public';
            visBtn.textContent = visibility === 'public' ? 'Make Unlisted' : 'Make Public';
            visBtn.className = 'btn ' + (visibility === 'public' ? 'btn-unlisted' : 'btn-public');
            visBtn.dataset.visibility = newVis;
          }
        }
        closeModal();
        showToast('Post updated.');
      } else {
        showToast('Error: ' + (data?.error || 'unknown'));
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save & Publish';
      }
    });

    // ── Main click handler ─────────────────────────────────────────────────
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('button[data-action]');
      if (!btn) return;

      const action = btn.dataset.action;
      const slug = btn.dataset.slug;
      const visibility = btn.dataset.visibility;

      if (action === 'approve') {
        btn.disabled = true;
        btn.textContent = 'Approving…';
        const { ok, data } = await apiCall({ action: 'approve', slug });
        if (ok) {
          document.getElementById('review-' + slug)?.remove();
          showToast('Post approved and published!');
        } else {
          showToast('Error: ' + (data.error || 'unknown'));
          btn.disabled = false;
          btn.textContent = '✓ Approve';
        }
      }

      if (action === 'reject') {
        if (!confirm('Delete this draft permanently?')) return;
        btn.disabled = true;
        btn.textContent = 'Deleting…';
        const { ok } = await apiCall({ action: 'reject', slug });
        if (ok) {
          document.getElementById('review-' + slug)?.remove();
          showToast('Draft deleted.');
        } else {
          btn.disabled = false;
          btn.textContent = '✕ Delete';
        }
      }

      if (action === 'visibility') {
        btn.disabled = true;
        btn.textContent = 'Saving…';
        const { ok } = await apiCall({ action: 'visibility', slug, visibility });
        if (ok) {
          const badge = document.getElementById('vis-' + slug);
          if (badge) {
            badge.textContent = visibility === 'public' ? '🌐 Public' : '🔒 Unlisted';
            badge.className = 'vis-badge ' + (visibility === 'public' ? 'vis-public' : 'vis-unlisted');
          }
          const newVis = visibility === 'public' ? 'unlisted' : 'public';
          btn.disabled = false;
          btn.textContent = visibility === 'public' ? 'Make Unlisted' : 'Make Public';
          btn.className = 'btn ' + (visibility === 'public' ? 'btn-unlisted' : 'btn-public');
          btn.dataset.visibility = newVis;
          showToast(visibility === 'public' ? 'Post is now public!' : 'Post is now unlisted.');
        } else {
          btn.disabled = false;
          btn.textContent = visibility === 'public' ? 'Make Public' : 'Make Unlisted';
        }
      }

      if (action === 'remove') {
        if (!confirm('Permanently delete this published post? This cannot be undone.')) return;
        btn.disabled = true;
        btn.textContent = 'Removing…';
        const { ok, data } = await apiCall({ action: 'remove', slug });
        if (ok) {
          document.getElementById('pub-' + slug)?.remove();
          showToast('Post removed.');
        } else {
          showToast('Error: ' + (data?.error || 'unknown'));
          btn.disabled = false;
          btn.textContent = 'Remove';
        }
      }

      if (action === 'edit') {
        openEditModal(slug);
      }
    });
  </script>
</body>
</html>
