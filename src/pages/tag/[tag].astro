---
// src/pages/tag/[tag].astro — SSR, no prerender
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

const { tag } = Astro.params;

const allPosts = (await getCollection('blog'))
  .filter(p => !p.id.startsWith('_review'))
  .filter(p => p.data.visibility !== 'private');

// Find the location that matches this tag slug
const location = [...new Set(
  allPosts.map(p => p.data.location).filter(Boolean)
)].find(loc =>
  loc.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') === tag
);

if (!location) {
  return new Response("Not found", { status: 404 });
}

const tagPosts = allPosts
  .filter(p => p.data.location === location)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const allLocations = [...new Set(
  allPosts.map(p => p.data.location).filter(l => l && !l.startsWith('Trip-'))
)].sort();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{location} — Vedic Journeys</title>
  <meta name="description" content={`Travel posts from ${location} — reflections, pilgrimage notes, and Advaita observations.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #faf7f2; --warm: #f0ebe0; --sand: #d4c5a9;
      --terracotta: #b5673d; --deep: #2c1810; --mid: #6b4c38; --light: #9a7b68;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Crimson Pro', Palatino, Georgia, serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--cream); color: var(--deep); font-family: var(--sans); }

    .page-header {
      background: var(--deep);
      padding: 4rem 2rem 3rem;
      text-align: center;
    }
    .breadcrumb {
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--sand); margin-bottom: 1.5rem; opacity: 0.7;
    }
    .breadcrumb a { color: var(--sand); text-decoration: none; }
    .breadcrumb a:hover { opacity: 1; }
    .page-title {
      font-family: var(--serif); font-size: clamp(1.8rem, 4vw, 3rem);
      color: #fff; margin-bottom: 0.5rem;
    }
    .page-subtitle { color: var(--sand); font-size: 0.9rem; opacity: 0.7; }

    .content-wrap {
      max-width: 1200px; margin: 0 auto;
      padding: 3rem 2rem 5rem;
      display: grid;
      grid-template-columns: 1fr 220px;
      gap: 4rem;
      align-items: start;
    }
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .empty {
      grid-column: 1/-1; text-align: center;
      padding: 4rem 0; color: var(--light);
    }

    .sidebar-title {
      font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--terracotta); margin-bottom: 1.25rem;
    }
    .sidebar-tags { display: flex; flex-direction: column; gap: 0.4rem; }
    .sidebar-tag {
      padding: 0.5rem 0.75rem; border-radius: 2px; text-decoration: none;
      font-size: 0.85rem; color: var(--mid); transition: all 0.15s;
      border: 1px solid transparent;
    }
    .sidebar-tag:hover { background: var(--warm); border-color: var(--sand); }
    .sidebar-tag.current { background: var(--terracotta); color: white; }

    @media (max-width: 860px) {
      .content-wrap { grid-template-columns: 1fr; gap: 2rem; }
      .sidebar { order: -1; }
      .sidebar-tags { flex-direction: row; flex-wrap: wrap; }
    }
    @media (max-width: 580px) {
      .posts-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <Header />

  <div class="page-header">
    <p class="breadcrumb">
      <a href="/">Home</a> &nbsp;/&nbsp;
      <a href="/blog">Journeys</a> &nbsp;/&nbsp;
      {location}
    </p>
    <h1 class="page-title">📍 {location}</h1>
    <p class="page-subtitle">{tagPosts.length} post{tagPosts.length !== 1 ? 's' : ''}</p>
  </div>

  <div class="content-wrap">
    <div class="posts-grid">
      {tagPosts.length === 0
        ? <p class="empty">No posts found for this destination.</p>
        : tagPosts.map(post => <PostCard post={post} />)
      }
    </div>

    <aside class="sidebar">
      <p class="sidebar-title">Other destinations</p>
      <div class="sidebar-tags">
        {allLocations.map(loc => (
          
            href={`/tag/${loc.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`}
            class={`sidebar-tag ${loc === location ? 'current' : ''}`}
          >
            {loc}
          </a>
        ))}
      </div>
    </aside>
  </div>

  <Footer />
</body>
</html>
