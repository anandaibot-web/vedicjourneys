---
// src/pages/about.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="About — Vedic Journeys"
    description="Vedic Journeys is a platform for yatris — travellers on the inner and outer path — to document their pilgrimages through writing, reflection, and Advaita philosophy."
  />
  <style>
    :root {
      --cream:      #faf7f2;
      --warm:       #f0ebe0;
      --sand:       #d4c5a9;
      --terracotta: #b5673d;
      --saffron:    #e8922a;
      --deep:       #2c1810;
      --mid:        #6b4c38;
      --light:      #9a7b68;
      --serif:      'Playfair Display', 'Georgia', serif;
      --sans:       'Crimson Pro', 'Palatino Linotype', Georgia, serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--cream);
      color: var(--deep);
      font-family: var(--sans);
      font-size: 18px;
      line-height: 1.8;
    }

    /* ── Hero ── */
    .hero {
      background: var(--deep);
      padding: 7rem 2rem 6rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: 'यात्रा';
      position: absolute;
      font-family: var(--serif);
      font-size: 22rem;
      color: rgba(255,255,255,0.02);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      white-space: nowrap;
    }

    .hero-eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 2rem;
    }

    .hero-title {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 700;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 2rem;
    }

    .hero-title em {
      font-style: italic;
      color: var(--saffron);
    }

    .hero-sanskrit {
      font-size: 1.1rem;
      color: var(--sand);
      opacity: 0.7;
      font-style: italic;
      margin-bottom: 0.5rem;
    }

    .hero-translation {
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      color: var(--light);
    }

    /* ── Sections ── */
    .content {
      max-width: 780px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ── What is this ── */
    .what-section {
      padding: 6rem 0 4rem;
    }

    .section-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 700;
      color: var(--deep);
      line-height: 1.2;
      margin-bottom: 2rem;
    }

    .prose p {
      color: var(--mid);
      margin-bottom: 1.5rem;
      font-size: 1.05rem;
    }

    .prose p:last-child { margin-bottom: 0; }

    .prose strong {
      color: var(--deep);
      font-weight: 600;
    }

    /* ── Pull quote ── */
    .pull-quote {
      border-left: 3px solid var(--terracotta);
      padding: 1.5rem 2rem;
      margin: 3rem 0;
      background: var(--warm);
      border-radius: 0 4px 4px 0;
    }

    .pull-quote p {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-style: italic;
      color: var(--deep);
      line-height: 1.5;
      margin: 0;
    }

    .pull-quote cite {
      display: block;
      margin-top: 0.75rem;
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--light);
      font-style: normal;
    }

    /* ── Divider ── */
    .divider {
      border: none;
      border-top: 1px solid var(--sand);
      margin: 4rem 0;
    }

    /* ── Philosophy ── */
    .philosophy-section {
      padding: 4rem 0;
    }

    /* ── Destinations ── */
    .destinations-section {
      padding: 4rem 0;
    }

    .destinations-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--sand);
      border: 1px solid var(--sand);
      border-radius: 4px;
      overflow: hidden;
      margin-top: 2.5rem;
    }

    .destination-item {
      background: var(--warm);
      padding: 1.75rem 2rem;
      transition: background 0.2s;
    }

    .destination-item:hover { background: white; }

    .destination-name {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--deep);
      margin-bottom: 0.4rem;
    }

    .destination-desc {
      font-size: 0.85rem;
      color: var(--light);
      line-height: 1.5;
    }

    /* ── How it works ── */
    .how-section {
      padding: 4rem 0;
    }

    .steps {
      margin-top: 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .step {
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
      border-bottom: 1px solid var(--warm);
      align-items: start;
    }

    .step:last-child { border-bottom: none; }

    .step-number {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--deep);
      color: #fff;
      font-family: var(--serif);
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 0.2rem;
    }

    .step-title {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--deep);
      margin-bottom: 0.4rem;
    }

    .step-desc {
      font-size: 0.95rem;
      color: var(--mid);
      line-height: 1.6;
    }

    /* ── CTA / contact ── */
    .contact-section {
      background: var(--deep);
      padding: 6rem 2rem;
      text-align: center;
      margin-top: 5rem;
    }

    .contact-inner {
      max-width: 600px;
      margin: 0 auto;
    }

    .contact-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 1.5rem;
    }

    .contact-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 700;
      color: #fff;
      margin-bottom: 1.25rem;
      line-height: 1.2;
    }

    .contact-desc {
      color: var(--sand);
      font-size: 1rem;
      opacity: 0.8;
      margin-bottom: 2.5rem;
      line-height: 1.8;
    }

    .contact-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--terracotta);
      color: #fff;
      padding: 0.875rem 2rem;
      border-radius: 2px;
      text-decoration: none;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
      transition: background 0.2s;
    }

    .btn-primary:hover { background: var(--saffron); }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 1px solid rgba(212,197,169,0.4);
      color: var(--sand);
      padding: 0.875rem 2rem;
      border-radius: 2px;
      text-decoration: none;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
      transition: all 0.2s;
    }

    .btn-secondary:hover {
      border-color: var(--sand);
      color: #fff;
    }

    .contact-note {
      margin-top: 2rem;
      font-size: 0.78rem;
      color: var(--light);
      letter-spacing: 0.05em;
    }

    @media (max-width: 600px) {
      .destinations-grid { grid-template-columns: 1fr; }
      .hero::before { font-size: 10rem; }
    }
  </style>
</head>
<body>
  <Header />

  <!-- ── Hero ── -->
  <section class="hero">
    <p class="hero-eyebrow">About Vedic Journeys</p>
    <h1 class="hero-title">
      Every journey is<br />
      an <em>inner</em> inquiry.
    </h1>
    <p class="hero-sanskrit">अथातो ब्रह्मजिज्ञासा</p>
    <p class="hero-translation">Now, therefore, the inquiry into Brahman. — Brahma Sutras 1.1.1</p>
  </section>

  <!-- ── What is Vedic Journeys ── -->
  <div class="content">
    <section class="what-section">
      <p class="section-eyebrow">What is this</p>
      <h2 class="section-title">A platform for yatris — travellers on the inner and outer path.</h2>
      <div class="prose">
        <p>
          Vedic Journeys is not a travel blog in the conventional sense. It is a living record of
          <strong>yatras</strong> — pilgrimages undertaken not merely to reach a destination, but to
          encounter the self along the way. Each post here is a diary entry: grounded in real
          landscapes, real altitude, real effort, and real stillness.
        </p>
        <p>
          The premise is simple. A yatri sends their photographs. The platform listens — to the
          light in the image, the altitude in the metadata, the silence between the peaks — and
          returns a fully written, personally voiced blog post, ready to share. The technology
          disappears. What remains is the story.
        </p>
        <p>
          This is a space for those who travel with a question rather than an itinerary. Who find
          the Himalayas not merely scenic but <strong>instructive</strong>. Who have stood at 5,000
          metres and felt, however briefly, the loosening of what they thought they were.
        </p>
      </div>

      <blockquote class="pull-quote">
        <p>"The outer journey is the map. The inner journey is the territory."</p>
        <cite>— The spirit of every yatra</cite>
      </blockquote>
    </section>

    <hr class="divider" />

    <!-- ── Philosophy ── -->
    <section class="philosophy-section">
      <p class="section-eyebrow">The philosophical lens</p>
      <h2 class="section-title">Advaita Vedanta — the view from non-duality.</h2>
      <div class="prose">
        <p>
          Every post on this platform is written through the lens of <strong>Advaita Vedanta</strong>
          — the ancient Indian philosophical tradition that holds all apparent separation to be
          illusory. The mountain and the one who stands before it are not two. The pilgrim and the
          pilgrimage are not two.
        </p>
        <p>
          This is not religion. It is a <strong>way of seeing</strong>. When you read a post here,
          you will find a canonical Sanskrit sloka — from the Bhagavad Gita, the Upanishads, or the
          Ashtavakra Gita — placed alongside the landscape it illuminates. Not as decoration, but as
          a lens that sharpens what the eye alone cannot resolve.
        </p>
        <p>
          The Advaita thread running through every journey asks the same question the Brahma Sutras
          open with: <em>athātho brahma jijñāsā</em> — now, therefore, the inquiry into what
          is real. High altitude, thin air, and the vast indifference of stone have a way of making
          that inquiry feel urgent.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- ── Destinations ── -->
    <section class="destinations-section">
      <p class="section-eyebrow">Where yatris have walked</p>
      <h2 class="section-title">The landscapes that ask the deepest questions.</h2>
      <div class="destinations-grid">
        <div class="destination-item">
          <p class="destination-name">🏔️ Kailash & Manasarovar</p>
          <p class="destination-desc">The axis mundi. Circumambulation at 5,000m. The lake that reflects nothing but sky.</p>
        </div>
        <div class="destination-item">
          <p class="destination-name">🕌 Lhasa & Tibet</p>
          <p class="destination-desc">The Potala Palace. Barkhor circuit. A civilisation built on the premise of impermanence.</p>
        </div>
        <div class="destination-item">
          <p class="destination-name">🙏 Kedarnath & Badrinath</p>
          <p class="destination-desc">The char dham. Stone temples in glacial valleys. Devotion as a physical act.</p>
        </div>
        <div class="destination-item">
          <p class="destination-name">🗻 Everest Region</p>
          <p class="destination-desc">Sagarmatha — the forehead of the sky. The world at its most indifferent and most alive.</p>
        </div>
        <div class="destination-item">
          <p class="destination-name">🛕 Kathmandu & Nepal</p>
          <p class="destination-desc">Boudhanath. Pashupatinath. A valley where the sacred is simply the ordinary, seen clearly.</p>
        </div>
        <div class="destination-item">
          <p class="destination-name">✦ And beyond</p>
          <p class="destination-desc">Every landscape that asks you to stop, look, and question what you thought was solid.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- ── How it works ── -->
    <section class="how-section">
      <p class="section-eyebrow">How it works</p>
      <h2 class="section-title">From photograph to published story — in minutes.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div>
            <p class="step-title">You send your photos</p>
            <p class="step-desc">
              Invited yatris send their travel photographs directly via WhatsApp — exactly as
              you'd share them with a friend. No apps, no uploads, no forms.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div>
            <p class="step-title">The platform reads the journey</p>
            <p class="step-desc">
              Location, altitude, light, landscape, human presence — the platform analyses
              every visual detail alongside any GPS or context you provide, building a factual
              foundation for the writing.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div>
            <p class="step-title">A post is written in your voice</p>
            <p class="step-desc">
              A full, structured travel diary entry is generated — grounded in what the images
              actually show, written with a reflective Advaita lens, complete with a canonical
              Sanskrit sloka relevant to the journey.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <div>
            <p class="step-title">You receive the link</p>
            <p class="step-desc">
              Within minutes, a link to your published post arrives on WhatsApp. Unlisted by
              default — yours to share with whoever you choose, or keep as a private diary.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ── Contact / CTA ── -->
  <section class="contact-section">
    <div class="contact-inner">
      <p class="contact-eyebrow">Join as a yatri</p>
      <h2 class="contact-title">
        This platform is invite-only.<br />
        If you've found your way here, reach out.
      </h2>
      <p class="contact-desc">
        Vedic Journeys is currently open to a small circle of yatris — travellers whose
        journeys carry the weight of genuine inquiry. If that sounds like you, we'd like
        to hear from you.
      </p>
      <div class="contact-actions">
        <a
          href="https://wa.me/919606015491?text=Namaste%2C%20I%27d%20like%20to%20join%20Vedic%20Journeys%20as%20a%20yatri."
          class="btn-primary"
          target="_blank"
          rel="noopener"
        >
          <!-- WhatsApp icon -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Message on WhatsApp
        </a>
        <a href="/blog" class="btn-secondary">
          Read the journal →
        </a>
      </div>
      <p class="contact-note">+91 96060 15491 &nbsp;·&nbsp; Responses within a day or two.</p>
    </div>
  </section>

  <Footer />
</body>
</html>
