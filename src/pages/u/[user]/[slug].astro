---
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import { marked } from 'marked';

const { user, slug } = Astro.params;

const BLOG_ROOT = path.join(process.cwd(), 'src/content/blog');
const mdPath = path.join(BLOG_ROOT, user, `${slug}.md`);

if (!fs.existsSync(mdPath)) {
  return new Response("Not found", { status: 404 });
}

const raw = fs.readFileSync(mdPath, 'utf8');
const { data: frontmatter, content } = matter(raw);

if (frontmatter.user !== user) {
  return new Response("Not found", { status: 404 });
}

const htmlContent = marked(content);

const noindex = frontmatter.visibility !== "public";
const siteUrl = "https://vedicjourneys.vercel.app";
const canonicalUrl = `${siteUrl}/u/${user}/${slug}`;
const heroImage = frontmatter.heroImage || "";
const pubDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
  : "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter.title} | Vedic Journeys</title>
    {frontmatter.description && <meta name="description" content={frontmatter.description} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {frontmatter.keywords?.length > 0 && <meta name="keywords" content={frontmatter.keywords.join(", ")} />}
    <meta property="og:type" content="article" />
    <meta property="og:title" content={frontmatter.title} />
    {frontmatter.description && <meta property="og:description" content={frontmatter.description} />}
    {heroImage && <meta property="og:image" content={heroImage} />}
    <meta property="og:url" content={canonicalUrl} />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; font-family: Georgia, "Times New Roman", serif; background: #fdfcf8; color: #1a1a1a; line-height: 1.75; }
      .hero { width: 100%; max-height: 70vh; overflow: hidden; background: #111; }
      .hero img { width: 100%; height: 70vh; object-fit: cover; object-position: center; display: block; opacity: 0.92; }
      .container { max-width: 760px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      .meta { font-family: sans-serif; font-size: 0.85rem; color: #777; margin: 0.5rem 0 2rem; display: flex; flex-wrap: wrap; gap: 0.4rem 1rem; }
      h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 700; line-height: 1.25; margin: 1.5rem 0 0.5rem; color: #111; }
      article h2 { font-size: 1.3rem; margin-top: 2.5rem; color: #222; border-bottom: 1px solid #e8e3d8; padding-bottom: 0.4rem; }
      article p { margin: 1rem 0; }
      article blockquote { border-left: 3px solid #c8aa6e; margin: 1.5rem 0; padding: 0.5rem 0 0.5rem 1.25rem; color: #555; font-style: italic; }
      .badge { display: inline-block; background: #f0ebe0; color: #666; font-size: 0.72rem; font-family: sans-serif; padding: 0.2rem 0.6rem; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.05em; }
      .unlisted-notice { background: #fff8e1; border: 1px solid #ffe082; border-radius: 6px; padding: 0.75rem 1rem; font-size: 0.85rem; font-family: sans-serif; color: #795548; margin-bottom: 1.5rem; }
    </style>
  </head>
  <body>
    {heroImage && (
      <div class="hero">
        <img src={heroImage} alt={frontmatter.title} loading="eager" />
      </div>
    )}
    <div class="container">
      {noindex && (
        <div class="unlisted-notice">
          🔒 This post is unlisted — only people with the link can see it.
        </div>
      )}
      <h1>{frontmatter.title}</h1>
      <div class="meta">
        {frontmatter.location && <span>📍 {frontmatter.location}</span>}
        {pubDate && <span>📅 {pubDate}</span>}
        {frontmatter.readTime && <span>⏱ {frontmatter.readTime} min read</span>}
        {(frontmatter.keywords || []).slice(0, 3).map((kw: string) => (
          <span class="badge">{kw}</span>
        ))}
      </div>
      <article set:html={htmlContent} />
    </div>
  </body>
</html>
