---
import { SITE_TITLE } from '../consts';
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="brand">✦ {SITE_TITLE}</a>
    <div class="links">
      <a href="/" class:list={['nav-link', { active: pathname === '/' }]}>Home</a>
      <a href="/blog" class:list={['nav-link', { active: pathname.startsWith('/blog') }]}>Journeys</a>
      <a href="/vedanta" class:list={['nav-link', { active: pathname.startsWith('/vedanta') }]}>Vedanta</a>
      <a href="/about" class:list={['nav-link', { active: pathname === '/about' }]}>About</a>
      <a href="/contribute" class="contribute-btn">Share your journey →</a>
    </div>
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">☰</button>
  </nav>
  <div class="mobile-menu" id="mobile-menu">
    <a href="/">Home</a>
    <a href="/blog">Journeys</a>
    <a href="/vedanta">Vedanta</a>
    <a href="/about">About</a>
    <a href="/contribute">Share your journey →</a>
  </div>
</header>

<style>
  :root {
    --cream: #faf7f2; --sand: #d4c5a9; --terracotta: #b5673d;
    --deep: #2c1810; --mid: #6b4c38; --light: #9a7b68;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'Crimson Pro', Palatino, Georgia, serif;
  }
  header {
    background: var(--deep);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(212,197,169,0.15);
  }
  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--sand); }
  .links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-link {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--sand);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 2px;
    transition: color 0.2s;
    opacity: 0.8;
  }
  .nav-link:hover, .nav-link.active { color: #fff; opacity: 1; }
  .contribute-btn {
    font-family: var(--sans);
    font-size: 0.85rem;
    background: var(--terracotta);
    color: #fff;
    text-decoration: none;
    padding: 0.45rem 1rem;
    border-radius: 2px;
    margin-left: 0.75rem;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .contribute-btn:hover { background: #9a4f2e; }
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--sand);
    font-size: 1.3rem;
    cursor: pointer;
    padding: 0.5rem;
  }
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--deep);
    border-top: 1px solid rgba(212,197,169,0.15);
    padding: 1rem 2rem;
    gap: 0.75rem;
  }
  .mobile-menu a {
    color: var(--sand);
    text-decoration: none;
    font-family: var(--sans);
    font-size: 1rem;
    padding: 0.35rem 0;
  }
  .mobile-menu a:last-child {
    color: var(--terracotta);
    font-weight: 600;
  }
  .mobile-menu.open { display: flex; }
  @media (max-width: 680px) {
    .links { display: none; }
    .menu-toggle { display: block; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>
