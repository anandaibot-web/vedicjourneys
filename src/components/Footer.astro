---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-mark">✦</span>
      <span class="footer-title">Vedic Journeys</span>
      <p class="footer-tagline">Travel as inquiry, not escape.</p>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <p class="col-title">Explore</p>
        <a href="/">Home</a>
        <a href="/blog">All Journeys</a>
        <a href="/about">About</a>
      </div>
      <div class="footer-col">
        <p class="col-title">Contribute</p>
        <a href="/contribute">Share your journey</a>
        <a href="/contribute/login">Yatri portal</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>सर्वं खल्विदं ब्रह्म — All this is indeed Brahman.</p>
    <p>&copy; {today.getFullYear()} Vedic Journeys. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: #2c1810;
    color: #9a7b68;
    font-family: 'Crimson Pro', Palatino, Georgia, serif;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 2rem 2rem;
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .footer-brand { max-width: 260px; }
  .footer-mark { font-size: 1.5rem; color: #b5673d; }
  .footer-title {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    color: #faf7f2;
    margin: 0.4rem 0;
  }
  .footer-tagline { font-size: 0.9rem; color: #d4c5a9; font-style: italic; margin: 0; }
  .footer-links { display: flex; gap: 3rem; flex-wrap: wrap; }
  .footer-col { display: flex; flex-direction: column; gap: 0.5rem; }
  .col-title {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #b5673d;
    margin: 0 0 0.25rem;
  }
  .footer-col a {
    color: #d4c5a9;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: #faf7f2; }
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    border-top: 1px solid rgba(212,197,169,0.15);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: #9a7b68;
  }
  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; gap: 2rem; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }
</style>
