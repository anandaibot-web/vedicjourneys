---
// src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = (await getCollection('blog'))
  .filter(p => !p.id.startsWith('_review'))
  .filter(p => p.data.visibility !== 'private')
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const locations = [...new Set(
  allPosts
    .map(p => p.data.location)
    .filter(l => l && l.trim() !== '' && !l.startsWith('Trip-'))
)].sort();
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="All Journeys — Vedic Journeys"
    description="Every post — pilgrimages, mountain reflections, and Advaita travel writing."
  />
  <style>
    :root {
      --cream:      #faf7f2;
      --warm:       #f0ebe0;
      --sand:       #d4c5a9;
      --terracotta: #b5673d;
      --saffron:    #e8922a;
      --deep:       #2c1810;
      --mid:        #6b4c38;
      --light:      #9a7b68;
      --serif:      'Playfair Display', 'Georgia', serif;
      --sans:       'Crimson Pro', 'Palatino Linotype', Georgia, serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--cream);
      color: var(--deep);
      font-family: var(--sans);
    }

    .page-header {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem 2rem;
      border-bottom: 1px solid var(--sand);
      margin-bottom: 2rem;
    }

    .page-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 700;
      color: var(--deep);
      margin-bottom: 0.5rem;
    }

    .page-subtitle {
      color: var(--light);
      font-size: 1rem;
    }

    /* ── Toolbar ── */
    .toolbar {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .search-wrap {
      position: relative;
      flex: 1;
      min-width: 220px;
      max-width: 360px;
    }

    .search-input {
      width: 100%;
      padding: 0.7rem 1rem 0.7rem 2.5rem;
      border: 1px solid var(--sand);
      border-radius: 2px;
      background: white;
      font-family: var(--sans);
      font-size: 0.95rem;
      color: var(--deep);
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus { border-color: var(--terracotta); }
    .search-input::placeholder { color: var(--light); }

    .search-icon {
      position: absolute;
      left: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--light);
      pointer-events: none;
    }

    /* Location filter chips */
    .filter-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }

    .chip {
      padding: 0.4rem 0.9rem;
      border: 1px solid var(--sand);
      border-radius: 20px;
      font-size: 0.78rem;
      cursor: pointer;
      background: white;
      color: var(--mid);
      transition: all 0.15s;
      user-select: none;
    }

    .chip:hover, .chip.active {
      background: var(--terracotta);
      border-color: var(--terracotta);
      color: white;
    }

    /* ── Post count ── */
    .post-count {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem 1.5rem;
      font-size: 0.8rem;
      color: var(--light);
      letter-spacing: 0.05em;
    }

    /* ── Grid ── */
    .posts-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem 5rem;
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .no-results {
      grid-column: 1 / -1;
      text-align: center;
      padding: 4rem 0;
      color: var(--light);
      font-size: 1rem;
    }

    @media (max-width: 900px) {
      .posts-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 580px) {
      .posts-grid { grid-template-columns: 1fr; }
      .toolbar { flex-direction: column; align-items: stretch; }
      .search-wrap { max-width: 100%; }
    }
  </style>
</head>
<body>
  <Header />

  <div class="page-header">
    <h1 class="page-title">All Journeys</h1>
    <p class="page-subtitle">{allPosts.length} posts · pilgrimages, reflections & high-altitude wandering</p>
  </div>

  <div class="toolbar">
    <div class="search-wrap">
      <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        id="search-input"
        class="search-input"
        placeholder="Search posts…"
        autocomplete="off"
      />
    </div>
    <div class="filter-chips">
      <span class="chip active" data-location="all">All</span>
      {locations.map(loc => (
        <span
          class="chip"
          data-location={loc}
        >
          {loc}
        </span>
      ))}
    </div>
  </div>

  <p class="post-count" id="post-count">{allPosts.length} posts</p>

  <section class="posts-section">
    <div class="posts-grid" id="posts-grid">
      {allPosts.map(post => (
        <div
          class="post-item"
          data-title={post.data.title.toLowerCase()}
          data-location={(post.data.location || '').toLowerCase()}
          data-keywords={(post.data.keywords || []).join(' ').toLowerCase()}
          data-desc={(post.data.description || '').toLowerCase()}
        >
          <PostCard post={post} />
        </div>
      ))}
    </div>
  </section>

  <Footer />

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const chips = document.querySelectorAll<HTMLElement>('.chip');
    const items = document.querySelectorAll<HTMLElement>('.post-item');
    const countEl = document.getElementById('post-count');

    let activeLocation = 'all';
    let searchQuery = '';

    function filterPosts() {
      let visible = 0;
      items.forEach(item => {
        const title    = item.dataset.title    || '';
        const location = item.dataset.location || '';
        const keywords = item.dataset.keywords || '';
        const desc     = item.dataset.desc     || '';

        const matchesSearch = !searchQuery ||
          title.includes(searchQuery) ||
          location.includes(searchQuery) ||
          keywords.includes(searchQuery) ||
          desc.includes(searchQuery);

        const matchesLocation = activeLocation === 'all' ||
          location.includes(activeLocation.toLowerCase());

        if (matchesSearch && matchesLocation) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      if (countEl) {
        countEl.textContent = `${visible} post${visible !== 1 ? 's' : ''}`;
      }
    }

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.trim().toLowerCase();
      filterPosts();
    });

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeLocation = chip.dataset.location || 'all';
        filterPosts();
      });
    });
  </script>
</body>
</html>
